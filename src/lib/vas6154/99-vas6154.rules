# /etc/udev/rules.d/99-vas6154.rules
# VAS 6154 USB VCI - udev rules for Linux
# DERHAN AutoMatrix Pro
#
# Grants access to plugdev group (non-root use)
# Install: sudo cp 99-vas6154.rules /etc/udev/rules.d/
#          sudo udevadm control --reload-rules && sudo udevadm trigger
#          sudo usermod -aG plugdev $USER  (then re-login)

# ──────────────────────────────────────────────
# Softing AG - VAS 6154 (all hardware revisions)
# VID 0x19B2
# ──────────────────────────────────────────────

# VAS 6154 v1
SUBSYSTEM=="usb", ATTRS{idVendor}=="19b2", ATTRS{idProduct}=="0003", \
    MODE="0666", GROUP="plugdev", \
    SYMLINK+="vas6154_%n", \
    TAG+="uaccess", \
    ENV{ID_MM_DEVICE_IGNORE}="1"

# VAS 6154 v2 (operational)
SUBSYSTEM=="usb", ATTRS{idVendor}=="19b2", ATTRS{idProduct}=="0008", \
    MODE="0666", GROUP="plugdev", \
    SYMLINK+="vas6154_%n", \
    TAG+="uaccess", \
    ENV{ID_MM_DEVICE_IGNORE}="1"

# VAS 6154 v3 (CAN-FD capable)
SUBSYSTEM=="usb", ATTRS{idVendor}=="19b2", ATTRS{idProduct}=="000c", \
    MODE="0666", GROUP="plugdev", \
    SYMLINK+="vas6154_%n", \
    TAG+="uaccess", \
    ENV{ID_MM_DEVICE_IGNORE}="1"

# VAS 6154 DFU mode (firmware update)
SUBSYSTEM=="usb", ATTRS{idVendor}=="19b2", ATTRS{idProduct}=="0009", \
    MODE="0666", GROUP="plugdev", \
    SYMLINK+="vas6154_dfu_%n", \
    TAG+="uaccess", \
    ENV{ID_MM_DEVICE_IGNORE}="1"

# VAS 6154 Bootloader mode
SUBSYSTEM=="usb", ATTRS{idVendor}=="19b2", ATTRS{idProduct}=="000a", \
    MODE="0666", GROUP="plugdev", \
    SYMLINK+="vas6154_boot_%n", \
    TAG+="uaccess", \
    ENV{ID_MM_DEVICE_IGNORE}="1"

# ──────────────────────────────────────────────
# Softing - generic VCI (catch-all for Softing)
# ──────────────────────────────────────────────
SUBSYSTEM=="usb", ATTRS{idVendor}=="19b2", \
    MODE="0666", GROUP="plugdev", \
    TAG+="uaccess", \
    ENV{ID_MM_DEVICE_IGNORE}="1"

# ──────────────────────────────────────────────
# USB-to-Serial based VCI (FTDI chip fallback)
# ──────────────────────────────────────────────
SUBSYSTEM=="usb", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6001", \
    MODE="0666", GROUP="plugdev", \
    TAG+="uaccess"

SUBSYSTEM=="usb", ATTRS{idVendor}=="0403", ATTRS{idProduct}=="6014", \
    MODE="0666", GROUP="plugdev", \
    TAG+="uaccess"

# ──────────────────────────────────────────────
# ttyUSB / ttyACM devices for K-Line access
# ──────────────────────────────────────────────
KERNEL=="ttyUSB[0-9]*", ATTRS{idVendor}=="19b2", \
    MODE="0666", GROUP="dialout", \
    SYMLINK+="vas6154_kline_%n"

KERNEL=="ttyACM[0-9]*", ATTRS{idVendor}=="19b2", \
    MODE="0666", GROUP="dialout", \
    SYMLINK+="vas6154_kline_%n"

# ──────────────────────────────────────────────
# Prevent ModemManager from grabbing the device
# (ModemManager interferes with serial-based VCIs)
# ──────────────────────────────────────────────
SUBSYSTEM=="usb", ATTRS{idVendor}=="19b2", ENV{ID_MM_DEVICE_IGNORE}="1"
SUBSYSTEM=="usb", ATTRS{idVendor}=="0403", ENV{ID_MM_DEVICE_IGNORE}="1"
