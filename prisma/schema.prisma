// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Vehicle {
  id             String   @id @default(cuid())
  name           String
  vin            String   @unique
  brand          String
  model          String?
  year           Int?
  engine         String?
  transmission   String?
  status         String   @default("healthy") // healthy, warning, critical, offline
  health         Int      @default(100)
  lastConnected  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  serviceRecords ServiceRecord[]
  dtcCodes       DtcCode[]
  diagSessions   DiagnosticSession[]
}

model ServiceRecord {
  id          String   @id @default(cuid())
  vehicleId   String
  serviceType String   // oil_change, brake_service, tire_service, battery, inspection, transmission, other
  date        DateTime
  mileage     Int?
  cost        Float?
  status      String   @default("scheduled") // scheduled, completed, overdue
  mechanic    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model DtcCode {
  id          String   @id @default(cuid())
  vehicleId   String
  code        String   // e.g., P0300, P0171, C0035
  description String
  severity    String   @default("warning") // critical, warning, info
  status      String   @default("active") // active, pending, stored, cleared
  module      String?  // ECM, TCM, ABS, SRS, BCM, IC
  freezeFrame String?  // JSON string with freeze frame data
  createdAt   DateTime @default(now())
  clearedAt   DateTime?
  updatedAt   DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model DiagnosticSession {
  id          String   @id @default(cuid())
  vehicleId   String
  deviceType  String?  // VAS 6154, Bosch KTS, ELM327, etc.
  protocol    String?  // ISO 15765-4, SAE J2534, etc.
  startTime   DateTime @default(now())
  endTime     DateTime?
  dataPoints  Int      @default(0)
  status      String   @default("active") // active, completed, failed
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model DeviceConnection {
  id              String   @id @default(cuid())
  deviceName      String
  deviceType      String   // vas6154, bosch_kts, elm327, daimler_xentry
  connectionType  String   // wifi, usb, bluetooth
  protocol        String?
  status          String   @default("available") // available, connected, unavailable
  signalStrength  Int?
  lastConnected   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AIPrediction {
  id              String   @id @default(cuid())
  vehicleId       String?
  component       String
  prediction      String
  severity        String   @default("warning") // critical, warning, monitor, ok
  probability     Int      @default(50) // 0-100
  confidence      Int      @default(80) // 0-100
  symptoms        String?  // JSON array string
  recommendation  String?
  estimatedCost   String?
  timeHorizon     String?  // e.g., "2-4 weeks", "1-3 months"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
